# E2E 测试环境变量模板
# 复制为 .env 后填入实际值（.env 已被 .gitignore 排除，不会提交）

# Playwright 基础 URL（本地默认 http://127.0.0.1:3000）
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# 预置测试账号（用于 globalSetup 登录和 reset）
E2E_TEST_USER_EMAIL=e2e-test@example.com
E2E_TEST_USER_PASSWORD=E2eTest123!

# Reset API Secret（后端 /api/e2e/reset-user-data 的验证密钥）
# 要求：128-bit 随机字符串，仅 staging 环境可用
E2E_RESET_SECRET=replace-with-actual-secret

# ingestion 超时（可选，单位毫秒，默认 60000）
# E2E_INGESTION_TIMEOUT=60000
