{
  "name": "frontend-next",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:desktop": "BUILD_TARGET=desktop next build",
    "start": "next start",
    "test": "vitest",
    "typecheck": "next typegen && tsc --noEmit",
    "generate:contracts": "bash ../scripts/generate-contracts.sh",
    "check:contracts-drift": "pnpm generate:contracts && git -C .. diff --exit-code -- frontend_next/lib/contracts/generated/",
    "sync:legal": "bash scripts/sync-legal-assets.sh",
    "prebuild": "pnpm sync:legal"
  },
  "dependencies": {
    "@tanstack/react-query": "5.99.2",
    "@tauri-apps/api": "^2",
    "@tiptap/extensions": "^3.22.4",
    "@tiptap/markdown": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "dompurify": "^3.4.9",
    "gray-matter": "^4.0.3",
    "next": "16.2.4",
    "next-intl": "4.9.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "1.53.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "24.6.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "jsdom": "27.0.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
