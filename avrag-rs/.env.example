AVRAG_API_ADDR=0.0.0.0:8080
AVRAG_PUBLIC_BASE_URL=http://127.0.0.1:8080
AVRAG_RUN_MIGRATIONS=true
AVRAG_OBJECT_ROOT=/home/chuan/.local/share/avrag-dev/objects
PROMPT_DIR=./prompts
PROMPT_SUMMARY_VERSION=v1

# Set DATABASE_URL to enable PostgreSQL-backed M1/M2 runtime.
# Example:
# DATABASE_URL=postgres://avrag:***@127.0.0.1:5432/avrag_rs
DATABASE_URL=postgres://avrag:***@127.0.0.1:5432/avrag_rs

# ======================================
# Queue / Redis
# ======================================
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ======================================
# Milvus retrieval data plane
# ======================================
MILVUS_URL=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DATABASE=default
MILVUS_COLLECTION_PREFIX=avrag
MILVUS_TEXT_VECTOR_DIM=1024
MILVUS_MULTIMODAL_VECTOR_DIM=1024
MILVUS_METRIC_TYPE=COSINE
RAG_GRAPH_RETRIEVAL_ENABLED=true
RAG_PARALLEL_CHANNELS_ENABLED=true

# ======================================
# Embedding / Rerank / LLM Models
# ======================================
# DashScope-only profile:
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=sk-292b16fbc7b34cb9b82ec3293aa3717e
EMBEDDING_DIMENSIONS=1024
EMBEDDING_TIMEOUT_MS=15000
# Worker alias for text vector sizing. Keep this equal to EMBEDDING_DIMENSIONS.
# For DashScope text-embedding-v4, the official default is 1024.
AVRAG_EMBEDDING_DIM=1024

# DashScope multimodal embedding / rerank
DASHSCOPE_API_KEY=sk-292b16fbc7b34cb9b82ec3293aa3717e
MM_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding
MM_EMBEDDING_API_KEY=sk-292b16fbc7b34cb9b82ec3293aa3717e
MM_EMBEDDING_MODEL=tongyi-embedding-vision-plus-2026-03-06
MM_EMBEDDING_API_STYLE=dashscope_multimodal_embedding
MM_EMBEDDING_DIMENSIONS=1024
MM_EMBEDDING_TIMEOUT_MS=30000

MM_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
MM_RERANK_API_KEY=sk-292b16fbc7b34cb9b82ec3293aa3717e
MM_RERANK_MODEL=qwen3-vl-rerank
MM_RERANK_API_STYLE=dashscope_vl_rerank
MM_RERANK_TIMEOUT_MS=30000

# Text rerank (non-VL fallback) - also DashScope
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANK_API_KEY=sk-292b16fbc7b34cb9b82ec3293aa3717e
RERANK_MODEL=qwen3-vl-rerank
RERANK_TIMEOUT_MS=15000
RERANK_MAX_DOCS=32
RERANK_MAX_DOC_CHARS=2000

# ======================================
# Unified LLM Configuration
# ======================================
# Agent LLM: Chat, RAG, WebSearch — requires strong agentic reasoning.
AGENT_LLM_BASE_URL=https://api.deepseek.com
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=deepseek-v4-pro
AGENT_LLM_TIMEOUT_MS=180000
AGENT_LLM_TEMPERATURE=0.2
AGENT_LLM_ENABLE_THINKING=true
AGENT_LLM_ENABLE_CACHE=true

# Memory LLM: Session summary, user profile extraction — fast and cheap.
MEMORY_LLM_BASE_URL=https://api.deepseek.com
MEMORY_LLM_API_KEY=
MEMORY_LLM_MODEL=deepseek-v4-flash
MEMORY_LLM_TIMEOUT_MS=30000
MEMORY_LLM_TEMPERATURE=0.2
MEMORY_LLM_ENABLE_THINKING=false

# Ingestion LLM: Document summary, index, triplets, VLM page summary.
INGESTION_LLM_BASE_URL=https://www.dmxapi.cn/v1
INGESTION_LLM_API_KEY=
INGESTION_LLM_MODEL=deepseek-v4-flash
INGESTION_LLM_TIMEOUT_MS=30000
INGESTION_LLM_TEMPERATURE=0.2

# Paddle OCR (Baidu AI Studio) — PDF C/D pages + standalone images (png/jpg/…)
# API root (client appends /jobs and /jobs/{id}) — not .../ocr/jobs
PADDLE_OCR_BASE_URL=https://paddleocr.aistudio-app.com/api/v2/ocr
PADDLE_OCR_API_TOKEN=
PADDLE_OCR_MODEL=PaddleOCR-VL-1.6
PADDLE_OCR_POLL_INTERVAL_SECS=5
PADDLE_OCR_JOB_TIMEOUT_SECS=3600
PADDLE_OCR_BATCH_PAGES=80
PADDLE_OCR_C_PRIME_MAX_SINGLE_JOBS=10
PADDLE_OCR_MAX_JOBS_PER_DOCUMENT=50
# When exceeded, remaining C/D pages degrade: LiteParse text extract (A) then visual raster (E)
PADDLE_OCR_MAX_CONCURRENT_JOBS=5
PADDLE_OCR_RESULT_CACHE_ENABLED=1
PADDLE_OCR_RESULT_CACHE_TTL_SECS=86400

# LiteParse (primary PDF parser)
LITEPARSE_OCR_ENABLED=0
# LITEPARSE_OCR_SERVER_URL=
LITEPARSE_OCR_LANGUAGE=zh
LITEPARSE_SCANNED_PAGE_THRESHOLD=100
LITEPARSE_TABLE_GARBLE_THRESHOLD=0.30
LITEPARSE_TABLE_HEAVY_THRESHOLD=10
LITEPARSE_FIG_RATIO_THRESHOLD=0.15
LITEPARSE_FIG_COUNT_THRESHOLD=2
LITEPARSE_TEXT_QUAL_THRESHOLD=0.5
LITEPARSE_DECORATIVE_MAX_AREA=0.03

# ======================================
# Search Mode / Search LLM
# ======================================
SEARCH_MODE=llm_tools
SEARCH_ENABLE_THINKING=true
SEARCH_TOOLS=web_search,web_extractor,code_interpreter
# SEARCH_LLM is deprecated — all search-agent LLM calls now use AGENT_LLM_*.
SEARCH_PROVIDER=brave_llm_context
# Brave LLM Context uses SEARCH_API_KEY with the X-Subscription-Token header.
SEARCH_BASE_URL=https://api.search.brave.com
SEARCH_API_KEY=
SEARCH_MAX_RESULTS=10
SEARCH_MAX_SUB_QUERIES=3
SEARCH_TIMEOUT_MS=30000
SEARCH_CITATION_REQUIRED=true
# Brave search runtime parameters (optional). Applied to all sub-queries.
# SEARCH_LANG=zh
# SEARCH_COUNTRY=CN
# SEARCH_FRESHNESS=pd

# ======================================
# Password Reset Email (163 SMTP compatible)
# ======================================
# Legacy-compatible provider switch. Keep "smtp" for 163 mailbox delivery.
EMAIL_PROVIDER=smtp
# 163 SMTP defaults
SMTP_HOST=smtp.163.com
SMTP_PORT=465
# 163 mailbox account and authorization code
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Optional display name shown in reset emails
SMTP_FROM_NAME="Context OSv6"
# Whether to require TLS when connecting to SMTP
SMTP_TLS=true
# Secret used to hash reset codes and reset tickets
RESET_CODE_SECRET=
# Enable worker-side analytics rollups and anomaly scans
ANALYTICS_ROLLUP_ENABLED=false
ANALYTICS_ROLLUP_INTERVAL_SECS=300

# ======================================
# Object Storage (PRD-required for upload)
# ======================================
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE=true
UPLOAD_URL_EXPIRE_SEC=900
DOWNLOAD_URL_EXPIRE_SEC=900
# Maximum single file upload size in bytes (default: 100 MB = 104857600)
AVRAG_MAX_UPLOAD_FILE_SIZE_BYTES=104857600

# ======================================
# Parser Backends
# ======================================
OFFICE_PARSER_BASE_URL=http://127.0.0.1:9090
# OFFICE_PARSER_API_KEY=
PDF_RENDERER_BASE_URL=http://127.0.0.1:9091
# PDF_RENDERER_BIND=127.0.0.1:9091
# Note: Milvus metrics uses host port 19091 (see docker-compose.milvus.yml) so 9091 stays free for this sidecar.
# PDF_RENDERER_TIMEOUT_MS=60000
# E2E llm_real PDF corpus (WSL paths via /mnt/e)
# E2E_LLM_REAL_ANTIFRAGILE_PDF=/mnt/e/OneDrive/桌面/知境笔记/Taleb_Antifragile__2012.pdf
# E2E_LLM_REAL_BLACK_SWAN_PDF=/mnt/e/OneDrive/桌面/知境笔记/the-black-swan_-the-impact-of-the-highly-improbable-second-edition-pdfdrive.com-.pdf
# PDF_VISUAL_PAGES_PER_CHUNK=4
# PDF_VISUAL_RENDER_STRATEGY=pixmap_72dpi
# MM_EMBEDDING_IMAGE_TOKEN_ESTIMATE=896
# INGESTION_VLM_TRIPLET_ENABLED=0
# INGESTION_TRIPLET_ENABLED=0
# INGESTION_VLM_SUMMARY_ENABLED=0
# INGESTION_PDF_MAX_PAGES=80
# E2E_PDF_MAX_PAGES=80
# INGESTION_TRIPLET_MIN_CONFIDENCE=0.6
# When true, OCR-successful pages still get page_raster multimodal chunks (default: false)
# INGESTION_PAGE_RASTER_WITH_OCR=false

# ======================================
# Security Scanning (optional)
# ======================================
# ClamAV daemon host/port for malware scanning.
# If unset or unreachable, scans are skipped (fail-open).
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ======================================
# Billing: Creem (https://creem.io)
# ======================================
# CREEM_API_KEY=creem_your_api_key
# CREEM_WEBHOOK_SECRET=whsec_your_webhook_secret
# Creem uses product_id (prod_xxx) for checkout sessions.
# CREEM_PRODUCT_PRO=prod_your_pro_product_id
# CREEM_PRODUCT_PLUS=prod_your_plus_product_id

# ======================================
# Billing: Alipay (https://open.alipay.com)
# ======================================
# ALIPAY_APP_ID=2021xxxxxxxxxxxx
# Paste the raw base64 key content (with or without PEM headers).
# ALIPAY_PRIVATE_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...
# ALIPAY_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...
# ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# ALIPAY_NOTIFY_URL=https://your-domain.com/webhooks/alipay
# ALIPAY_PRICE_PRO=39.00
# ALIPAY_PRICE_PLUS=19.00
