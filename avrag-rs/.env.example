AVRAG_API_ADDR=0.0.0.0:8080
AVRAG_PUBLIC_BASE_URL=http://127.0.0.1:8080
AVRAG_RUN_MIGRATIONS=true
AVRAG_OBJECT_ROOT=/home/chuan/.local/share/avrag-dev/objects
TANTIVY_INDEX_DIR=/home/chuan/.local/share/avrag-dev/tantivy-index
PROMPT_DIR=./prompts
PROMPT_INTENT_TEMPLATE_PATH=
PROMPT_INTENT_VERSION=freeze-v2
PROMPT_SUMMARY_VERSION=v1

# Set DATABASE_URL to enable PostgreSQL-backed M1/M2 runtime.
# Example:
# DATABASE_URL=postgres://avrag:avrag@127.0.0.1:5432/avrag_rs
DATABASE_URL=postgres://avrag:avrag@127.0.0.1:5432/avrag_rs

# ======================================
# Queue / Redis
# ======================================
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ======================================
# Retrieval backend
# ======================================
RETRIEVAL_BACKEND=milvus

# ======================================
# Qdrant legacy rollback adapter
# Set RETRIEVAL_BACKEND=legacy to use these values.
# ======================================
QDRANT_URL=http://127.0.0.1:6333
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_chunks
QDRANT_VECTOR_NAME=dense
QDRANT_MULTI_VECTOR=true
QDRANT_USE_TLS=false
# If an existing collection was created with a different size, recreate it or
# switch to a fresh collection name before ingesting again.

# ======================================
# Milvus retrieval data plane (default)
# ======================================
MILVUS_URL=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DATABASE=default
MILVUS_COLLECTION_PREFIX=avrag
MILVUS_TEXT_VECTOR_DIM=1024
MILVUS_MULTIMODAL_VECTOR_DIM=1024
MILVUS_METRIC_TYPE=COSINE
RAG_GRAPH_RETRIEVAL_ENABLED=true
RAG_PARALLEL_CHANNELS_ENABLED=true

# SiliconFlow shared key (legacy fallback; no longer required in the recommended
# DashScope + DMX profile below)
SILICONFLOW_API_KEY=

# ======================================
# Embedding / Rerank / LLM Models
# ======================================
# Recommended DashScope-only profile:
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_TIMEOUT_MS=15000
# Worker alias for text vector sizing. Keep this equal to EMBEDDING_DIMENSIONS.
# For DashScope text-embedding-v4, the official default is 1024.
AVRAG_EMBEDDING_DIM=1024

# DashScope multimodal embedding / rerank
DASHSCOPE_API_KEY=
MM_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding
MM_EMBEDDING_API_KEY=
MM_EMBEDDING_MODEL=qwen3-vl-embedding
MM_EMBEDDING_API_STYLE=dashscope_multimodal_embedding
MM_EMBEDDING_TIMEOUT_MS=30000

MM_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
MM_RERANK_API_KEY=
MM_RERANK_MODEL=qwen3-vl-rerank
MM_RERANK_API_STYLE=dashscope_vl_rerank
MM_RERANK_TIMEOUT_MS=30000

# Optional fallback only. Current non-VL rerank client still expects a
# SiliconFlow-style `/rerank` path. For DashScope-only runtime it is safer to
# leave RERANK_* unset and rely on MM_RERANK_*.
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=
RERANK_MODEL=Qwen/Qwen3-Reranker-8B
RERANK_TIMEOUT_MS=15000
RERANK_MAX_DOCS=32
RERANK_MAX_DOC_CHARS=2000

# Legacy RAG planner configuration. The product /api/v1/chat RAG path now uses
# ANSWER_LLM_* as the Main Agent model; keep INTENT_LLM_* only for legacy
# planner-compatible paths.
INTENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INTENT_LLM_API_KEY=
INTENT_LLM_MODEL=qwen3.5-flash
INTENT_LLM_TIMEOUT_MS=30000
INTENT_LLM_ENABLE_THINKING=false

# Main Agent model for mode routing, RAG execute-plan generation, general chat,
# and final answers.
ANSWER_LLM_BASE_URL=https://www.dmxapi.cn/v1
ANSWER_LLM_API_KEY=
ANSWER_LLM_MODEL=gemini-3-flash-preview-thinking
ANSWER_LLM_TIMEOUT_MS=180000
ANSWER_LLM_TEMPERATURE=0.2

SUMMARY_LLM_BASE_URL=https://www.dmxapi.cn/v1
SUMMARY_LLM_API_KEY=
SUMMARY_LLM_MODEL=gemini-3.1-flash-lite-preview
SUMMARY_LLM_TIMEOUT_MS=30000

# ======================================
# Search Mode / Search LLM
# ======================================
SEARCH_MODE=llm_tools
SEARCH_ENABLE_THINKING=true
SEARCH_TOOLS=web_search,web_extractor,code_interpreter
SEARCH_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SEARCH_LLM_API_KEY=
SEARCH_LLM_API_STYLE=auto
SEARCH_LLM_MODEL=qwen3.5-plus
SEARCH_LLM_TIMEOUT_MS=30000
SEARCH_PROVIDER=perplexity
PERPLEXITY_API_KEY=
SEARCH_BASE_URL=https://api.exa.ai
SEARCH_API_KEY=
SEARCH_PLANNER_ENABLED=true
SEARCH_QUERY_TYPE_ENABLED=true
SEARCH_EXTRACT_ENABLED=false
SEARCH_MAX_RESULTS=10
SEARCH_MAX_SUB_QUERIES=3
SEARCH_TIMEOUT_MS=30000
SEARCH_CITATION_REQUIRED=true

# ======================================
# Password Reset Email (163 SMTP compatible)
# ======================================
# Legacy-compatible provider switch. Keep "smtp" for 163 mailbox delivery.
EMAIL_PROVIDER=smtp
# 163 SMTP defaults
SMTP_HOST=smtp.163.com
SMTP_PORT=465
# 163 mailbox account and authorization code
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Optional display name shown in reset emails
SMTP_FROM_NAME="Context OSv6"
# Whether to require TLS when connecting to SMTP
SMTP_TLS=true
# Secret used to hash reset codes and reset tickets
RESET_CODE_SECRET=
# Enable worker-side analytics rollups and anomaly scans
ANALYTICS_ROLLUP_ENABLED=false
ANALYTICS_ROLLUP_INTERVAL_SECS=300

# ======================================
# Object Storage (PRD-required for upload)
# ======================================
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE=true
UPLOAD_URL_EXPIRE_SEC=900
DOWNLOAD_URL_EXPIRE_SEC=900

# ======================================
# Parser Backends
# ======================================
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_KEY=
# Optional: extract_v4 | legacy_v1_upload
# MINERU_API_MODE=extract_v4
OFFICE_PARSER_BASE_URL=http://127.0.0.1:9090
# OFFICE_PARSER_API_KEY=
