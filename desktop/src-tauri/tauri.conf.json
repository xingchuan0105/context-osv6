{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AVRag Desktop",
  "version": "0.1.0",
  "identifier": "com.avrag.desktop",
  "build": {
    "frontendDist": "../../frontend_next/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm --dir ../../frontend_next dev",
    "beforeBuildCommand": "pnpm --dir ../../frontend_next build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "AVRag Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
